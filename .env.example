# Copy this file to .env and fill in your values.
# In Vercel: add these as Environment Variables in the project settings.

# Supabase → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase → Project Settings → API → service_role secret key (NOT the anon key)
# This is used server-side only and is never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Set to "production" in Vercel (enables secure cookies)
NODE_ENV=production
