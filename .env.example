# Copy this file to .env and fill in your values.
# In Vercel: add these as Environment Variables in the project settings.

# Supabase → Project Settings → Database → Connection String → URI (Transaction Pooler)
# Use the "Transaction" pooler URL (port 6543) for serverless/Vercel deployments.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Set to "production" in Vercel (enables secure cookies + SSL)
NODE_ENV=production
